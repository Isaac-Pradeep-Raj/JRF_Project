<mujoco model="jrf_tilting_board_component">
    <compiler angle="radian" autolimits="true"/>

    <default>
        <joint damping="2.0" armature="0.05"/>
        <geom density="700" condim="3" friction="1.2 0.02 0.02" solref="0.045 1" solimp="0.65 0.96 0.01"/>
    </default>

    <worldbody>
        <!-- Component copy of the passive spring-loaded board used in scene.xml. -->
        <body name="board_base" pos="0.30 0 0.08">
            <joint name="board_hinge" type="hinge" axis="0 -1 0" range="-0.65 0.65" stiffness="20.0" damping="1.2"/>
            <geom name="board_geom" type="box" pos="0.30 0 0" size="0.30 0.085 0.015"
                  density="250" rgba="0.58 0.43 0.24 1" contype="1" conaffinity="1"/>
            <site name="board_hinge_site" pos="0 0 0.015" size="0.008" rgba="0.95 0.05 0.05 1"/>
            <site name="board_mid_surface" pos="0.30 0 0.015" size="0.008" rgba="0.05 0.05 0.95 1"/>
            <site name="board_end_surface" pos="0.60 0 0.015" size="0.008" rgba="0.05 0.80 0.05 1"/>
        </body>
    </worldbody>
</mujoco>
